# --- Server ---
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# --- Database ---
DATABASE_URL="mysql://mp:mp@localhost:3306/manager_prompts"

# --- Session / cookies ---
# 32+ bytes em base64. Gere com: npm run gen:secret
SESSION_SECRET=
COOKIE_SECURE=false
COOKIE_DOMAIN=

# --- BYOK (chaves dos usuários) ---
# 32 bytes em base64. Gere com: npm run gen:secret
ENCRYPTION_KEY=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# --- Providers (modelos trocáveis sem rebuild) ---
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash

# --- Rate limits ---
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_IMPROVE_MAX=20

# --- Sessão ---
# Timeout de ociosidade em minutos. Sessão expira se ficar parada além disso.
# 0 desliga a checagem (só vale a expiração absoluta: 24h ou 30d com "manter conectado").
SESSION_IDLE_TIMEOUT_MIN=30

# --- SMTP (reset de senha) ---
# Em dev, deixar vazio: o mailer cai para stdout (loga o e-mail no console).
# Em prod, preencher para envios reais (recomendado: Brevo, Gmail App Password, SendGrid).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=manager-prompts

# MFA — chave HMAC pro hash do código de email (32 bytes base64)
# Gerar: openssl rand -base64 32
MFA_HMAC_KEY=
